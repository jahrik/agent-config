# Never commit secrets or local overrides
*.env
*.key
*.pem
*.secret
*.token
local/
secrets/
.secrets.baseline
private/

# Runtime state — this repo is cloned to ~/.config/agents, where MCP servers
# may drop SQLite DBs. Never track them; the dispatcher DB belongs in ~/.mcp.
*.db
*.sqlite
*.sqlite3

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Node
node_modules/
